{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/api/(.*)",
        "destination": "/server.js"
      },
      {
        "source": "/uploads/(.*)",
        "destination": "/server.js"
      }
    ],
    "fallback": [
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ]
  }
}
